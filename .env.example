# Скопируйте в .env и заполните значениями из Firebase Console
# https://console.firebase.google.com → Project settings → Your apps → Web app

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# После заполнения:
# 1. В Firebase Console включите Authentication → Email/Password
# 2. Создайте Firestore Database
# 3. Примените правила из firestore.rules
# 4. Перезапустите: npm run web -- --clear
